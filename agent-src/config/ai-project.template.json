{
  "project": {
    "name": "ProjectName",
    "slug": "ProjectSlug",
    "serenaProject": "ProjectSlug",
    "description": "Describe your Project in a few words."
  },
  "repository": {
    "slug": "RepositoryName",
    "defaultBranch": "main"
  },
  "ticketing": {
    "backend": "file",
    "github": {
    },
    "file": {
      "dir": ".tickets/issues",
      "metadataFile": ".tickets/metadata.json"
    },
    "azureDevOps": {
      "organization": "YourAdoOrg",
      "project": "YourAdoProject",
      "featureType": "Issue",
      "bugType": "Issue",
      "processTemplate": "basic",
      "stateMapping": {
        "new": "To Do",
        "in-progress": "Doing",
        "review": "Doing",
        "test": "Doing",
        "failed": "Doing",
        "acceptance-test": "Doing"
      }
    }
  },
  "git": {
    "branchPattern": "feat/<issue-number>_<slug>",
    "prTarget": "main"
  }
}
