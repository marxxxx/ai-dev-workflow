{
  "project": {
    "name": "ProjectName",
    "slug": "ProjectSlug",
    "serenaProject": "ProjectSlug",
    "description": "Describe your Project in a few words."
  },
  "repository": {
    "slug": "RepositoryName",
    "defaultBranch": "main"
  },
  "ticketing": {
    "backend": "file",
    "includePath": ".agents/includes/ticketing.md",
    "itemNoun": "issue",
    "github": {
    },
    "file": {
      "dir": ".tickets/issues",
      "metadataFile": ".tickets/metadata.json"
    }
  },
  "workflow": {
    "states": [
      {
        "id": "new",
        "label": "status:new",
        "frontmatter": "new",
        "meaning": "Ready to build",
        "next": "in-progress"
      },
      {
        "id": "in-progress",
        "label": "status:in-progress",
        "frontmatter": "in-progress",
        "meaning": "Implementation running or interrupted",
        "next": "review"
      },
      {
        "id": "review",
        "label": "status:review",
        "frontmatter": "review",
        "meaning": "Awaiting code review",
        "next": "test"
      },
      {
        "id": "test",
        "label": "status:test",
        "frontmatter": "test",
        "meaning": "Ready for acceptance QA",
        "next": "acceptance-test"
      },
      {
        "id": "failed",
        "label": "status:failed",
        "frontmatter": "failed",
        "meaning": "Review or QA failure",
        "next": "in-progress"
      },
      {
        "id": "acceptance-test",
        "label": "status:acceptance-test",
        "frontmatter": "acceptance-test",
        "meaning": "PR/human acceptance pending",
        "next": null
      }
    ],
    "artifacts": {
      "implementationNotes": "Implementation Notes",
      "reviewFeedback": "Code Review Feedback",
      "testResults": "Test Results"
    }
  },
  "git": {
    "branchPattern": "feat/<issue-number>_<slug>",
    "prTarget": "main"
  }
}
